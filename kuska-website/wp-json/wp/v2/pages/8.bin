preset=&#8221;default&#8221; header_3_text_align=&#8221;center&#8221; header_3_font_size=&#8221;26px&#8221; global_colors_info=&#8221;{}&#8221;]<\/p>\n<h3>Coping Skills<\/h3>\n<p>[\/et_pb_text][\/et_pb_column][\/et_pb_row][et_pb_row _builder_version=&#8221;4.27.4&#8243; _module_preset=&#8221;default&#8221; global_colors_info=&#8221;{}&#8221;][et_pb_column type=&#8221;4_4&#8243; _builder_version=&#8221;4.27.4&#8243; _module_preset=&#8221;default&#8221; global_colors_info=&#8221;{}&#8221;][et_pb_button button_url=&#8221;\/about&#8221; button_text=&#8221;Learn more&#8221; button_alignment=&#8221;center&#8221; _builder_version=&#8221;4.27.4&#8243; _module_preset=&#8221;default&#8221; custom_button=&#8221;on&#8221; global_colors_info=&#8221;{}&#8221;][\/et_pb_button][\/et_pb_column][\/et_pb_row][\/et_pb_section][et_pb_section fb_built=&#8221;1&#8243; prev_background_color=&#8221;#ffffff&#8221; next_background_color=&#8221;#ffffff&#8221; _builder_version=&#8221;4.27.4&#8243; _module_preset=&#8221;default&#8221; background_color=&#8221;gcid-84868e6b-0706-4a57-a1cc-24348dceb5ae&#8221; custom_padding=&#8221;200px||200px|||&#8221; top_divider_style=&#8221;clouds2&#8243; bottom_divider_style=&#8221;clouds2&#8243; bottom_divider_flip=&#8221;vertical&#8221; global_colors_info=&#8221;{%22gcid-84868e6b-0706-4a57-a1cc-24348dceb5ae%22:%91%22background_color%22%93}&#8221;][et_pb_row column_structure=&#8221;1_2,1_2&#8243; _builder_version=&#8221;4.27.4&#8243; _module_preset=&#8221;default&#8221; global_colors_info=&#8221;{}&#8221;][et_pb_column type=&#8221;1_2&#8243; _builder_version=&#8221;4.27.4&#8243; _module_preset=&#8221;default&#8221; global_colors_info=&#8221;{}&#8221;][et_pb_image src=&#8221;https:\/\/kuska.co\/wp-content\/uploads\/2025\/11\/a-woman-teaching-a-child-how-to-use-a-weighing-bal-2025-10-17-00-47-38-utc.jpg&#8221; title_text=&#8221;a-woman-teaching-a-child-how-to-use-a-weighing-bal-2025-10-17-00-47-38-utc&#8221; _builder_version=&#8221;4.27.4&#8243; _module_preset=&#8221;default&#8221; border_radii=&#8221;on|25px|25px|25px|25px&#8221; border_width_all=&#8221;14px&#8221; border_color_all=&#8221;gcid-64840f85-baf8-4549-a37c-c6c9c34ff86f&#8221; global_colors_info=&#8221;{%22gcid-64840f85-baf8-4549-a37c-c6c9c34ff86f%22:%91%22border_color_all%22%93}&#8221;][\/et_pb_image][\/et_pb_column][et_pb_column type=&#8221;1_2&#8243; _builder_version=&#8221;4.27.4&#8243; _module_preset=&#8221;default&#8221; global_colors_info=&#8221;{}&#8221;][et_pb_text _builder_version=&#8221;4.27.4&#8243; _module_preset=&#8221;default&#8221; global_colors_info=&#8221;{}&#8221;]<\/p>\n<h2 class=\"preFade fadeIn\" id=\"yui_3_17_2_1_1746214525649_568\">Why Choose Us?<\/h2>\n<p>[\/et_pb_text][et_pb_text _builder_version=&#8221;4.27.4&#8243; _module_preset=&#8221;default&#8221; global_colors_info=&#8221;{}&#8221;]<\/p>\n<h3>Locally Owned &amp; Operated<\/h3>\n<p>[\/et_pb_text][et_pb_text _builder_version=&#8221;4.27.4&#8243; _module_preset=&#8221;default&#8221; global_colors_info=&#8221;{}&#8221;]<\/p>\n<p><span>We are dedicated to supporting families affected by autism spectrum disorder (ASD) in our community. Our team of highly educated and compassionate therapists is committed to providing personalized ABA therapy services that meet the unique needs and strengths of each individual. We understand that every family\u2019s journey with autism is different, which is why we offer a wide range of services that can be customized to meet each family\u2019s specific needs. Our goal is to empower individuals with ASD to achieve greater independence, improve their quality of life, and reach their full potential.<\/span><\/p>\n<p>[\/et_pb_text][\/et_pb_column][\/et_pb_row][\/et_pb_section][et_pb_section fb_built=&#8221;1&#8243; _builder_version=&#8221;4.27.4&#8243; _module_preset=&#8221;default&#8221; global_colors_info=&#8221;{}&#8221;][et_pb_row _builder_version=&#8221;4.27.4&#8243; _module_preset=&#8221;default&#8221; global_colors_info=&#8221;{}&#8221;][et_pb_column type=&#8221;4_4&#8243; _builder_version=&#8221;4.27.4&#8243; _module_preset=&#8221;default&#8221; global_colors_info=&#8221;{}&#8221;][et_pb_text _builder_version=&#8221;4.27.4&#8243; _module_preset=&#8221;default&#8221; global_colors_info=&#8221;{}&#8221;]<\/p>\n<h2>Our Core Values<\/h2>\n<p>[\/et_pb_text][\/et_pb_column][\/et_pb_row][et_pb_row column_structure=&#8221;1_2,1_2&#8243; _builder_version=&#8221;4.27.4&#8243; _module_preset=&#8221;default&#8221; global_colors_info=&#8221;{}&#8221;][et_pb_column type=&#8221;1_2&#8243; _builder_version=&#8221;4.27.4&#8243; _module_preset=&#8221;default&#8221; global_colors_info=&#8221;{}&#8221;][et_pb_text _builder_version=&#8221;4.27.4&#8243; _module_preset=&#8221;default&#8221; global_colors_info=&#8221;{}&#8221;]<\/p>\n<h3>Kuska<\/h3>\n<p>[\/et_pb_text][et_pb_text _builder_version=&#8221;4.27.4&#8243; _module_preset=&#8221;default&#8221; text_text_color=&#8221;#004e85&#8243; text_font_size=&#8221;16px&#8221; global_colors_info=&#8221;{}&#8221;]<\/p>\n<p>We succeed together. We believe the greatest outcomes will occur only when our clinical team works together with the families we serve and when our clinicians work as a team to support each other. Kuska means you never go it alone. It means fostering an environment of psychological safety where we grow from our mistakes.<\/p>\n<p>[\/et_pb_text][\/et_pb_column][et_pb_column type=&#8221;1_2&#8243; _builder_version=&#8221;4.27.4&#8243; _module_preset=&#8221;default&#8221; global_colors_info=&#8221;{}&#8221;][et_pb_image src=&#8221;https:\/\/kuska.co\/wp-content\/uploads\/2025\/05\/unsplash-image-Zyx1bK9mqmA.jpg&#8221; title_text=&#8221;unsplash-image-Zyx1bK9mqmA&#8221; _builder_version=&#8221;4.27.4&#8243; _module_preset=&#8221;default&#8221; border_radii=&#8221;on|25px|25px|25px|25px&#8221; border_width_all=&#8221;15px&#8221; border_color_all=&#8221;gcid-64840f85-baf8-4549-a37c-c6c9c34ff86f&#8221; global_colors_info=&#8221;{%22gcid-64840f85-baf8-4549-a37c-c6c9c34ff86f%22:%91%22border_color_all%22%93}&#8221;][\/et_pb_image][\/et_pb_column][\/et_pb_row][et_pb_row column_structure=&#8221;1_2,1_2&#8243; _builder_version=&#8221;4.27.4&#8243; _module_preset=&#8221;default&#8221; global_colors_info=&#8221;{}&#8221;][et_pb_column type=&#8221;1_2&#8243; _builder_version=&#8221;4.27.4&#8243; _module_preset=&#8221;default&#8221; global_colors_info=&#8221;{}&#8221;][et_pb_text _builder_version=&#8221;4.27.4&#8243; _module_preset=&#8221;default&#8221; global_colors_info=&#8221;{}&#8221;]<\/p>\n<div class=\"fe-block fe-block-16983b64da8ba8bd19f7\" id=\"yui_3_17_2_1_1746214525649_613\">\n<div class=\"sqs-block html-block sqs-block-html\" data-blend-mode=\"NORMAL\" data-block-type=\"2\" data-border-radii=\"{&quot;topLeft&quot;:{&quot;unit&quot;:&quot;px&quot;,&quot;value&quot;:0.0},&quot;topRight&quot;:{&quot;unit&quot;:&quot;px&quot;,&quot;value&quot;:0.0},&quot;bottomLeft&quot;:{&quot;unit&quot;:&quot;px&quot;,&quot;value&quot;:0.0},&quot;bottomRight&quot;:{&quot;unit&quot;:&quot;px&quot;,&quot;value&quot;:0.0}}\" id=\"block-16983b64da8ba8bd19f7\">\n<div class=\"sqs-block-content\" id=\"yui_3_17_2_1_1746214525649_616\">\n<div class=\"sqs-html-content\" id=\"yui_3_17_2_1_1746214525649_615\">\n<h3 class=\"preFade fadeIn\" id=\"yui_3_17_2_1_1746214525649_614\">Quality Care<\/h3>\n<\/div>\n<\/div>\n<\/div>\n<\/div>\n<div class=\"fe-block fe-block-6af165f1ae96f1acf0aa\" id=\"yui_3_17_2_1_1746214525649_605\">\n<div class=\"sqs-block html-block sqs-block-html\" data-blend-mode=\"NORMAL\" data-block-type=\"2\" data-border-radii=\"{&quot;topLeft&quot;:{&quot;unit&quot;:&quot;px&quot;,&quot;value&quot;:0.0},&quot;topRight&quot;:{&quot;unit&quot;:&quot;px&quot;,&quot;value&quot;:0.0},&quot;bottomLeft&quot;:{&quot;unit&quot;:&quot;px&quot;,&quot;value&quot;:0.0},&quot;bottomRight&quot;:{&quot;unit&quot;:&quot;px&quot;,&quot;value&quot;:0.0}}\" id=\"block-6af165f1ae96f1acf0aa\">\n<div class=\"sqs-block-content\" id=\"yui_3_17_2_1_1746214525649_608\">\n<div class=\"sqs-html-content\" id=\"yui_3_17_2_1_1746214525649_607\"><\/div>\n<\/div>\n<\/div>\n<\/div>\n<p>[\/et_pb_text][et_pb_text _builder_version=&#8221;4.27.4&#8243; _module_preset=&#8221;default&#8221; text_font_size=&#8221;16px&#8221; global_colors_info=&#8221;{}&#8221;]<\/p>\n<p>Kuska clinicians are committed to competent, trauma-informed, and compassionate care. Data-informed, individualized plans paired with evidence-based methods is how we do ABA. We believe quality care comes from quality training, both when you join and throughout your journey with us.<\/p>\n<p>[\/et_pb_text][\/et_pb_column][et_pb_column type=&#8221;1_2&#8243; _builder_version=&#8221;4.27.4&#8243; _module_preset=&#8221;default&#8221; global_colors_info=&#8221;{}&#8221;][et_pb_image src=&#8221;https:\/\/kuska.co\/wp-content\/uploads\/2025\/05\/unsplash-image-DKHPbzfU1Ts.jpg&#8221; title_text=&#8221;unsplash-image-DKHPbzfU1Ts&#8221; _builder_version=&#8221;4.27.4&#8243; _module_preset=&#8221;default&#8221; border_radii=&#8221;on|25px|25px|25px|25px&#8221; border_width_all=&#8221;15px&#8221; border_color_all=&#8221;gcid-64840f85-baf8-4549-a37c-c6c9c34ff86f&#8221; global_colors_info=&#8221;{%22gcid-64840f85-baf8-4549-a37c-c6c9c34ff86f%22:%91%22border_color_all%22%93}&#8221;][\/et_pb_image][\/et_pb_column][\/et_pb_row][et_pb_row column_structure=&#8221;1_2,1_2&#8243; _builder_version=&#8221;4.27.4&#8243; _module_preset=&#8221;default&#8221; global_colors_info=&#8221;{}&#8221;][et_pb_column type=&#8221;1_2&#8243; _builder_version=&#8221;4.27.4&#8243; _module_preset=&#8221;default&#8221; global_colors_info=&#8221;{}&#8221;][et_pb_text _builder_version=&#8221;4.27.4&#8243; _module_preset=&#8221;default&#8221; global_colors_info=&#8221;{}&#8221;]<\/p>\n<div class=\"fe-block fe-block-960d7ceffe65338f72d6\" id=\"yui_3_17_2_1_1746214525649_625\">\n<div class=\"sqs-block html-block sqs-block-html\" data-blend-mode=\"NORMAL\" data-block-type=\"2\" data-border-radii=\"{&quot;topLeft&quot;:{&quot;unit&quot;:&quot;px&quot;,&quot;value&quot;:0.0},&quot;topRight&quot;:{&quot;unit&quot;:&quot;px&quot;,&quot;value&quot;:0.0},&quot;bottomLeft&quot;:{&quot;unit&quot;:&quot;px&quot;,&quot;value&quot;:0.0},&quot;bottomRight&quot;:{&quot;unit&quot;:&quot;px&quot;,&quot;value&quot;:0.0}}\" id=\"block-960d7ceffe65338f72d6\">\n<div class=\"sqs-block-content\" id=\"yui_3_17_2_1_1746214525649_628\">\n<div class=\"sqs-html-content\" id=\"yui_3_17_2_1_1746214525649_627\">\n<h3 class=\"preFade fadeIn\" id=\"yui_3_17_2_1_1746214525649_626\">Radical Candor<\/h3>\n<\/div>\n<\/div>\n<\/div>\n<\/div>\n<div class=\"fe-block fe-block-069e1c1978fd7a072c7d\">\n<div class=\"sqs-block html-block sqs-block-html\" data-blend-mode=\"NORMAL\" data-block-type=\"2\" data-border-radii=\"{&quot;topLeft&quot;:{&quot;unit&quot;:&quot;px&quot;,&quot;value&quot;:0.0},&quot;topRight&quot;:{&quot;unit&quot;:&quot;px&quot;,&quot;value&quot;:0.0},&quot;bottomLeft&quot;:{&quot;unit&quot;:&quot;px&quot;,&quot;value&quot;:0.0},&quot;bottomRight&quot;:{&quot;unit&quot;:&quot;px&quot;,&quot;value&quot;:0.0}}\" id=\"block-069e1c1978fd7a072c7d\">\n<div class=\"sqs-block-content\">\n<div class=\"sqs-html-content\"><\/div>\n<\/div>\n<\/div>\n<\/div>\n<p>[\/et_pb_text][et_pb_text _builder_version=&#8221;4.27.4&#8243; _module_preset=&#8221;default&#8221; text_font_size=&#8221;16px&#8221; global_colors_info=&#8221;{}&#8221;]<\/p>\n<div class=\"fe-block fe-block-069e1c1978fd7a072c7d\" id=\"yui_3_17_2_1_1746214525649_637\">\n<div class=\"sqs-block html-block sqs-block-html\" data-blend-mode=\"NORMAL\" data-block-type=\"2\" data-border-radii=\"{&quot;topLeft&quot;:{&quot;unit&quot;:&quot;px&quot;,&quot;value&quot;:0.0},&quot;topRight&quot;:{&quot;unit&quot;:&quot;px&quot;,&quot;value&quot;:0.0},&quot;bottomLeft&quot;:{&quot;unit&quot;:&quot;px&quot;,&quot;value&quot;:0.0},&quot;bottomRight&quot;:{&quot;unit&quot;:&quot;px&quot;,&quot;value&quot;:0.0}}\" id=\"block-069e1c1978fd7a072c7d\">\n<div class=\"sqs-block-content\" id=\"yui_3_17_2_1_1746214525649_641\">\n<div class=\"sqs-html-content\" id=\"yui_3_17_2_1_1746214525649_640\">\n<p class=\"preFade fadeIn\" id=\"yui_3_17_2_1_1746214525649_639\">Direct, respectful, and timely communication fosters clarity and accelerated growth for all stakeholders.<\/p>\n<\/div>\n<\/div>\n<\/div>\n<\/div>\n<div class=\"fe-block fe-block-5bb26eab7dbcebe318c1\" id=\"yui_3_17_2_1_1746214525649_364\">\n<div class=\"sqs-block image-block sqs-block-image sqs-stretched sqs-text-ready\" data-blend-mode=\"NORMAL\" data-block-type=\"5\" data-border-radii=\"{&quot;topLeft&quot;:{&quot;unit&quot;:&quot;px&quot;,&quot;value&quot;:0.0},&quot;topRight&quot;:{&quot;unit&quot;:&quot;px&quot;,&quot;value&quot;:0.0},&quot;bottomLeft&quot;:{&quot;unit&quot;:&quot;px&quot;,&quot;value&quot;:0.0},&quot;bottomRight&quot;:{&quot;unit&quot;:&quot;px&quot;,&quot;value&quot;:0.0}}\" id=\"block-5bb26eab7dbcebe318c1\">\n<div class=\"sqs-block-content\" id=\"yui_3_17_2_1_1746214525649_363\">\n<div class=\"image-block-outer-wrapper layout-caption-hidden design-layout-fluid image-position-left combination-animation-fade-in individual-animation-site-default sqs-narrow-width animation-loaded\" data-test=\"image-block-fluid-outer-wrapper\" id=\"yui_3_17_2_1_1746214525649_362\">\n<div class=\"fluid-image-animation-wrapper sqs-image sqs-block-alignment-wrapper\" data-animation-role=\"image\" data-animation-override=\"\" id=\"yui_3_17_2_1_1746214525649_361\">\n<div class=\"fluid-image-container sqs-image-content\" id=\"yui_3_17_2_1_1746214525649_360\">\n<div class=\"content-fill\" id=\"yui_3_17_2_1_1746214525649_357\">\n<div class=\"fluidImageOverlay\"><\/div>\n<\/div>\n<\/div>\n<\/div>\n<\/div>\n<\/div>\n<\/div>\n<\/div>\n<div class=\"fe-block fe-block-bddb625219185a3aae8d\">\n<div class=\"sqs-block html-block sqs-block-html\" data-blend-mode=\"NORMAL\" data-block-type=\"2\" data-border-radii=\"{&quot;topLeft&quot;:{&quot;unit&quot;:&quot;px&quot;,&quot;value&quot;:0.0},&quot;topRight&qu